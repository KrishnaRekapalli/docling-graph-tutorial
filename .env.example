# Copy this file to .env and fill in the keys you have.
# test_extraction.py auto-detects which provider to use based on what's present.
# Priority: openai > anthropic > gemini > local (ollama)

# Remote providers — add whichever you have
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Force a specific provider (overrides auto-detection)
# LLM_PROVIDER=openai     # openai / anthropic / gemini / local
